{
	"name": "@tobper/svelte-components",
	"version": "0.2.50",
	"description": "Svelte components",
	"license": "MIT",
	"author": "Tobias Persson",
	"repository": "github:tobper/svelte-components",
	"scripts": {
		"dev": "vite dev --port 5001 --host 0.0.0.0",
		"build": "vite build && npm run package",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package && publint",
		"prepublishOnly": "npm run package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:spelling": "cspell -c .vscode/cspell.json --no-progress **",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest",
		"lint": "eslint .",
		"preinstall": "npx only-allow pnpm"
	},
	"packageManager": "pnpm@10.33.2",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"peerDependencies": {
		"@floating-ui/dom": "^1.7.4",
		"@sveltejs/kit": "^2.49.3",
		"@tobper/eon": "^1.0.2",
		"svelte": "^5.55.10"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.61.1",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tabler/icons-svelte": "^3.44.0",
		"@types/eslint": "^9.6.1",
		"@types/ua-parser-js": "^0.7.39",
		"autoprefixer": "^10.5.0",
		"cspell": "^10.0.0",
		"eslint": "^10.4.0",
		"eslint-plugin-svelte": "^3.18.0",
		"globals": "^17.6.0",
		"publint": "^0.3.21",
		"svelte": "^5.55.10",
		"svelte-check": "^4.4.8",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0",
		"valibot": "^1.4.1",
		"vite": "^8.0.14",
		"vitest": "^4.1.7"
	},
	"dependencies": {
		"esm-env": "^1.2.2",
		"ua-parser-js": "^2.0.10"
	},
	"types": "./dist/index.d.ts",
	"type": "module"
}
